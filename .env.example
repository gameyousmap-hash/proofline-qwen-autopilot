# Recommended production path: Next.js -> Alibaba Cloud Function Compute -> Qwen Cloud
ALIBABA_AUTOPILOT_URL=
ALIBABA_AUTOPILOT_SECRET=

# Qwen Cloud / Alibaba Cloud Model Studio. Base URLs are workspace and region specific.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
